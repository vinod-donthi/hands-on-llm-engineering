# Week 2 — copy to .env in work dir (never commit)

OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# Ollama (default local)
OLLAMA_BASE_URL=http://localhost:11434

# PostgreSQL (Docker Compose default)
DATABASE_URL=postgresql+asyncpg://benchmark:benchmark@localhost:5432/benchmark_studio

# Cost guardrails
MAX_COST_USD_PER_REQUEST=0.05
DAILY_BUDGET_USD=5.00

# Optional
LOG_LEVEL=INFO
